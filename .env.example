# ============================================================
# .env.example — copy to .env and fill in real values
# .env is gitignored and must never be committed
# ============================================================

# ── LLM layer (required for Layer 4 semantic classification) ──
# Get from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ── Embeddings layer (required for Layer 2 semantic matching) ──
# Get from https://www.voyageai.com/
VOYAGE_API_KEY=pa-...

# ── GitHub (required for posting PR comments) ──
# Personal access token with repo scope, or use GITHUB_TOKEN in Actions
GITHUB_TOKEN=ghp_...

# ── Dashboard database (only needed if running the dashboard locally) ──
# Get from https://neon.tech/
NEON_DATABASE_URL=postgresql://user:password@ep-xxx-yyy.us-east-2.aws.neon.tech/neondb?sslmode=require

# ── Dashboard analytics (only needed if running the dashboard locally) ──
CLICKHOUSE_URL=https://abc123.us-east-1.aws.clickhouse.cloud:8443
CLICKHOUSE_USERNAME=default
CLICKHOUSE_PASSWORD=your-clickhouse-password

# ── Billing (only needed if running the dashboard locally) ──
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Email alerts (only needed if running the dashboard locally) ──
RESEND_API_KEY=re_...
ALERT_FROM_EMAIL=alerts@yourdomain.com
ALERT_EMAIL=you@yourdomain.com
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../...
