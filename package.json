{
  "name": "semantic-test-selector",
  "version": "0.1.0",
  "description": "Semantic test selector — ML-backed CI test selection",
  "scripts": {
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "build": "ncc build src/main.ts -o dist --source-map --license licenses.txt && cp -r node_modules/onnxruntime-node/bin ./bin"
  },
  "dependencies": {
    "@actions/core": "^1.11.1",
    "@actions/exec": "^1.1.1",
    "@actions/github": "^6.0.1",
    "@anthropic-ai/sdk": "^0.82.0",
    "fast-glob": "^3.3.3",
    "js-yaml": "^4.1.1",
    "onnxruntime-node": "^1.23.0",
    "openai": "^6.33.0",
    "tree-sitter-go": "^0.25.0",
    "tree-sitter-python": "^0.25.0",
    "tree-sitter-ruby": "^0.23.1",
    "tree-sitter-typescript": "^0.23.2",
    "web-tree-sitter": "^0.26.8"
  },
  "devDependencies": {
    "@types/jest": "^29.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vercel/ncc": "^0.38.4",
    "eslint": "^8.0.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0"
  }
}
